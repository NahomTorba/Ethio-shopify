<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= @shop.name %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-blue-50 to-indigo-100 min-h-screen flex items-center justify-center p-4">
  <div class="max-w-md w-full bg-white rounded-2xl shadow-xl overflow-hidden">
    <% if @shop.logo_url %>
      <div class="h-48 bg-cover bg-center" style="background-image: url('<%= @shop.logo_url %>')"></div>
    <% else %>
      <div class="h-32 bg-gradient-to-r from-indigo-500 to-purple-600"></div>
    <% end %>
    
    <div class="p-8">
      <h1 class="text-3xl font-bold text-gray-800 mb-2"><%= @shop.name %></h1>
      <p class="text-gray-600 mb-6"><%= @shop.welcome_message || "Welcome to our shop!" %></p>
      
      <div class="space-y-3">
        <button onclick="Telegram.WebApp.expand()" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 px-4 rounded-lg transition">
          Browse Products
        </button>
        
        <% if @shop.web_app_button_url %>
          <a href="<%= @shop.web_app_button_url %>" class="block w-full text-center bg-green-500 hover:bg-green-600 text-white font-semibold py-3 px-4 rounded-lg transition">
            Open Shop
          </a>
        <% end %>
      </div>
    </div>
  </div>

  <script>
    Telegram.WebApp.ready();
  </script>
</body>
</html>